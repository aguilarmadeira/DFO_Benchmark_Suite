      orcid: 'https://orcid.org/0000-0001-9523-3808'
  title: >-
    GLODS-SI: Scale-Invariant Global-Local Direct Search for Engineering
    Design Optimization
  journal: Journal of Computational Design and Engineering
  year: 2026
  notes: Manuscript ID JCDE-2026-065
